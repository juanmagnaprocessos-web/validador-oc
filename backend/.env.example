# --- Club da Cotação -------------------------------------------------
CLUB_LOGIN=usuario@magnaprotecao.com.br
CLUB_SENHA=SUBSTITUIR_SENHA
CLUB_API_BASE_V1=https://api.clubdacotacao.com.br/api
CLUB_API_BASE_V3=https://api.clubdacotacao.com.br/v3/api
CLUB_REQUEST_DELAY_MS=300
CLUB_MAX_RETRIES=5

# --- Pipefy ----------------------------------------------------------
# Token: https://app.pipefy.com/tokens
PIPEFY_TOKEN=eyJhbGciOiJIUzUxMiJ9.SUBSTITUIR_PELO_TOKEN_REAL
PIPEFY_API_URL=https://api.pipefy.com/graphql
PIPE_ID=305587531
PIPEFY_IDS_FILE=config/pipefy_ids.json

# --- Cilia (pendente de credenciais) ---------------------------------
CILIA_MODE=stub
CILIA_API_URL=
CILIA_LOGIN=
CILIA_SENHA=

# --- E-mail SMTP -----------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_SENHA=
