# ======================================================================
# Validador OC — configuração de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commitar .env no git.
# ======================================================================

# --- Club da Cotação -------------------------------------------------
CLUB_LOGIN=usuario@magnaprotecao.com.br
CLUB_SENHA=SUBSTITUIR_SENHA
CLUB_API_BASE_V1=https://api.clubdacotacao.com.br/api
CLUB_API_BASE_V3=https://api.clubdacotacao.com.br/v3/api
CLUB_REQUEST_DELAY_MS=300
CLUB_MAX_RETRIES=5

# --- Pipefy ----------------------------------------------------------
# Token: https://app.pipefy.com/tokens
PIPEFY_TOKEN=eyJhbGciOiJIUzUxMiJ9.SUBSTITUIR_PELO_TOKEN_REAL
PIPEFY_API_URL=https://api.pipefy.com/graphql
PIPE_ID=305587531
PIPEFY_IDS_FILE=config/pipefy_ids.json
# Pipe de Devolução de Peças (consultado pela R2 cross-time)
PIPEFY_PIPE_DEVOLUCAO_ID=305658860

# --- Cilia ----------------------------------------------------------
# Modos disponíveis:
#   deeplink = (DEFAULT) renderiza link clicável no relatório para o
#              analista validar manualmente. NÃO faz HTTP. Único modo
#              recomendado em produção — o Cilia usa reCAPTCHA Enterprise
#              que bloqueia scraping automatizado.
#   stub     = dados sintéticos (apenas para testes/desenvolvimento)
#   http     = cliente HTTP real com login automático (NÃO funciona
#              hoje por causa do reCAPTCHA Enterprise — código mantido
#              caso o Cilia abra uma API oficial no futuro)
#   off      = desativa Cilia inteiramente, sem coluna no relatório
CILIA_MODE=deeplink
CILIA_BASE_URL=https://sistema.cilia.com.br

# --- E-mail SMTP -----------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_SENHA=
SMTP_REMETENTE=processo2@magnaprotecao.com.br
EMAIL_ENABLED=false

# --- Aplicação -------------------------------------------------------
APP_ENV=development
DB_PATH=data/validador.db
RELATORIOS_DIR=relatorios
LOG_LEVEL=INFO
R3_TOLERANCIA_CENTAVOS=0
VALIDADOR_IDENTIFICADOR=validador-oc@magna

# --- Modo de operação -----------------------------------------------
# consulta   = sistema só lê e gera relatório, nenhuma escrita externa
#              (Pipefy/e-mail). Default seguro na fase de adoção.
# automatico = ações reais são aplicadas no Pipefy e e-mails enviados.
MODO_OPERACAO=consulta

# --- R2 peça repetida cruzada ---------------------------------------
# Janela em dias para detectar reincidência cross-time (mesma peça
# comprada para a mesma placa nos últimos N dias).
R2_JANELA_DIAS=90
# Modo: "alerta" (não bloqueia, só sinaliza no relatório),
#       "bloqueio" (move card para Informações Incorretas),
#       "off" (desliga a verificação cross-time).
R2_MODO=alerta
PIPEFY_FASES_CANCELAMENTO=Cancelados,Informações Incorretas

# --- CORS (origens permitidas, separadas por vírgula) ---------------
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------
# Bootstrap do primeiro usuário Admin (rodar uma vez por ambiente)
# ---------------------------------------------------------------
# Não há seed automático: o primeiro Admin é criado pela CLI.
# A senha gerada é exibida apenas no terminal e a troca é
# obrigatória no 1º login.
#
#   python -m app.cli criar-admin --username admin --nome "Administrador"
#
# Para definir a senha manualmente em vez de gerar, use --senha:
#   python -m app.cli criar-admin --username admin --nome "Administrador" --senha minhasenha
