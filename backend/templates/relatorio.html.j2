<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Validação OC — {{ data_d1 }}</title>
<style>
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
    margin: 0;
    padding: 24px;
    background: #f4f6fa;
    color: #1a2332;
  }
  h1 { margin: 0 0 8px; font-size: 24px; }
  .sub { color: #5a6c7f; margin-bottom: 24px; }
  .cards { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; margin-bottom: 24px; }
  .card { background: white; border-radius: 8px; padding: 14px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
  .card .num { font-size: 28px; font-weight: 700; margin: 4px 0; }
  .card .lbl { font-size: 11px; text-transform: uppercase; letter-spacing: .5px; color: #5a6c7f; }
  .card.ok .num { color: #17a34a; }
  .card.warn .num { color: #ea580c; }
  .card.err .num { color: #dc2626; }
  .card.ml .num { color: #d97706; }
  .card.muted .num { color: #6b7280; }
  table { width: 100%; background: white; border-collapse: collapse; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
  th { background: #1a2332; color: white; text-align: left; padding: 12px 10px; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; }
  td { padding: 10px; border-top: 1px solid #eef1f5; font-size: 13px; vertical-align: top; }
  tr:hover td { background: #fafbfd; }
  .tag { display: inline-block; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
  .tag.aprovada { background: #d1fae5; color: #065f46; }
  .tag.divergencia { background: #fed7aa; color: #9a3412; }
  .tag.bloqueada { background: #fecaca; color: #991b1b; }
  .tag.aguardando_ml { background: #fef3c7; color: #92400e; }
  .tag.ja_processada { background: #e5e7eb; color: #374151; }
  .motivo { color: #b91c1c; font-size: 12px; }
  .right { text-align: right; }
  .mono { font-family: "SF Mono", Consolas, monospace; }
  .meta { margin-top: 24px; padding: 16px; background: white; border-radius: 8px; font-size: 12px; color: #5a6c7f; }
</style>
</head>
<body>
  <h1>Validação de Ordens de Compra — {{ data_d1 }}</h1>
  <div class="sub">Gerado em {{ gerado_em }} · Executado por {{ executado_por }} · {{ 'DRY-RUN' if dry_run else 'APLICADO' }}</div>

  <div class="cards">
    <div class="card"><div class="lbl">Total OCs</div><div class="num">{{ total }}</div></div>
    <div class="card ok"><div class="lbl">Aprovadas</div><div class="num">{{ aprovadas }}</div></div>
    <div class="card warn"><div class="lbl">Divergências</div><div class="num">{{ divergentes }}</div></div>
    <div class="card err"><div class="lbl">Bloqueadas</div><div class="num">{{ bloqueadas }}</div></div>
    <div class="card ml"><div class="lbl">Aguardando ML</div><div class="num">{{ aguardando_ml }}</div></div>
    <div class="card muted"><div class="lbl">Já processadas</div><div class="num">{{ ja_processadas }}</div></div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Nº OC</th>
        <th>Placa</th>
        <th>Fornecedor</th>
        <th class="right">Valor Club</th>
        <th class="right">Valor PDF</th>
        <th class="right">Valor Cilia</th>
        <th class="right">Cot.</th>
        <th>Dup?</th>
        <th>Status</th>
        <th>Motivo</th>
        <th>Fase Atual</th>
        <th>Fase Destino</th>
      </tr>
    </thead>
    <tbody>
    {% for r in resultados %}
      <tr>
        <td class="mono">{{ r.oc.id_pedido }}</td>
        <td class="mono">{{ r.oc.identificador or "—" }}</td>
        <td>{{ (r.oc.fornecedor.for_nome if r.oc.fornecedor else "") or "—" }}</td>
        <td class="right mono">{{ "R$ %.2f"|format(r.valor_club) if r.valor_club else "—" }}</td>
        <td class="right mono">{{ "R$ %.2f"|format(r.valor_pdf) if r.valor_pdf else "—" }}</td>
        <td class="right mono">{{ "R$ %.2f"|format(r.valor_cilia) if r.valor_cilia else "—" }}</td>
        <td class="right">{{ r.qtd_cotacoes or 0 }}</td>
        <td>{{ r.peca_duplicada }}</td>
        <td><span class="tag {{ r.status.value }}">{{ {'aprovada':'Aprovada','divergencia':'Divergência','bloqueada':'Bloqueada','aguardando_ml':'ML — Manual','ja_processada':'Já processada'}[r.status.value] }}</span></td>
        <td class="motivo">
          {%- if r.status.value == 'aguardando_ml' -%}
            Fornecedor Mercado Livre — requer validação manual
          {%- elif r.status.value == 'ja_processada' -%}
            Card já estava em fase "{{ r.fase_pipefy_atual or '?' }}"
          {%- else -%}
            {{ r.motivo_resumido or "—" }}
          {%- endif -%}
        </td>
        <td>{{ r.fase_pipefy_atual or "—" }}</td>
        <td>{{ r.fase_destino.value if r.fase_destino else "—" }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <div class="meta">
    Pipe Pipefy: <span class="mono">{{ pipe_id }}</span> ·
    Validador: <span class="mono">{{ executado_por }}</span> ·
    Rastreabilidade: cada chamada de API foi registrada em <span class="mono">auditoria_api</span>.
  </div>
</body>
</html>
