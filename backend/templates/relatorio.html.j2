<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Validação OC — {{ data_d1 }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --brand-navy: #2c3464;
    --brand-red: #c53542;
    --navy-accent: #3d4a8a;
    --font-sans: "Inter Tight", -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
    --font-mono: "JetBrains Mono", "SF Mono", Consolas, monospace;
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-lg: 10px;
    --shadow-sm: 0 1px 2px rgba(0,0,0,.32);
    --shadow-md: 0 4px 12px rgba(0,0,0,.32);
    --shadow-lg: 0 8px 24px rgba(0,0,0,.42);
    /* Dark (padrão) */
    --bg-base: #0f1419;
    --surface: #1a2332;
    --surface-alt: #141b26;
    --surface-hover: #22304a;
    --border: #2d3a52;
    --border-row: #222d42;
    --text-primary: #e6ebf5;
    --text-secondary: #9fa8b8;
    --text-muted: #6b7689;
    --accent: #c53542;
    --accent-hover: #d84451;
    --accent-dim: #c5354220;
    --link: #6aa5ff;
    --link-hover: #8ebaff;
    --success: #4ade80;
    --success-bg: #0f3d2a;
    --success-fg: #86efac;
    --warning: #fbbf24;
    --warning-amber: #fb923c;
    --warning-bg: #3d2c0a;
    --warning-fg: #fde68a;
    --danger: #ef4444;
    --danger-bg: #3d1518;
    --danger-fg: #fca5a5;
    --info: #3b82f6;
    --info-bg: #12213d;
    --info-fg: #93c5fd;
  }

  [data-theme="light"] {
    --bg-base: #f4f6fa;
    --surface: #ffffff;
    --surface-alt: #fafbfd;
    --surface-hover: #eef2ff;
    --border: #d4dae8;
    --border-row: #eef1f5;
    --text-primary: #1a2332;
    --text-secondary: #5a6c7f;
    --text-muted: #8892a6;
    --shadow-sm: 0 1px 2px rgba(0,0,0,.06);
    --shadow-md: 0 2px 8px rgba(0,0,0,.08);
    --shadow-lg: 0 6px 20px rgba(0,0,0,.10);
    --link: #2563eb;
    --link-hover: #1d4ed8;
    --success: #16a34a;
    --success-bg: #d1fae5;
    --success-fg: #065f46;
    --warning: #ea580c;
    --warning-amber: #d97706;
    --warning-bg: #fed7aa;
    --warning-fg: #9a3412;
    --danger: #dc2626;
    --danger-bg: #fee2e2;
    --danger-fg: #991b1b;
    --info: #2563eb;
    --info-bg: #dbeafe;
    --info-fg: #1e40af;
  }

  * { box-sizing: border-box; }
  html { color-scheme: dark light; }
  body {
    font-family: var(--font-sans);
    margin: 0;
    padding: 24px;
    background: var(--bg-base);
    color: var(--text-primary);
    letter-spacing: -0.005em;
  }

  /* Header do relatório com toggle */
  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 2px solid var(--border);
  }
  .report-header h1 { margin: 0 0 6px; font-size: 22px; font-weight: 700; color: var(--text-primary); }
  .report-header .meta-inline { color: var(--text-secondary); font-size: 12px; margin: 0; }
  .report-header .meta-inline strong { color: var(--text-primary); }
  #theme-toggle {
    cursor: pointer;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 6px 12px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--text-secondary);
    transition: background 120ms ease, border-color 120ms ease;
  }
  #theme-toggle:hover { background: var(--surface-hover); border-color: var(--navy-accent); color: var(--text-primary); }

  /* Resumo executivo */
  .executive-summary {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--brand-red);
    border-radius: var(--radius-lg);
    padding: 14px 18px;
    margin-bottom: 16px;
    box-shadow: var(--shadow-sm);
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-primary);
  }
  .executive-summary .ok { color: var(--success); font-weight: 600; }
  .executive-summary .warn { color: var(--warning); font-weight: 600; }
  .executive-summary .err { color: var(--danger); font-weight: 600; }
  .executive-summary .ml { color: var(--warning-amber); font-weight: 600; }
  .executive-summary .muted { color: var(--text-muted); }

  /* Sumário com âncoras */
  nav.toc {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
    padding: 10px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  nav.toc a {
    font-size: 12px;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
  }
  nav.toc a:hover { background: var(--accent-dim); color: var(--accent); border-color: var(--accent-dim); }

  h1 { margin: 0 0 8px; font-size: 22px; font-weight: 700; }
  h2 { margin: 24px 0 10px; font-size: 16px; font-weight: 600; color: var(--text-primary); }
  .sub { color: var(--text-secondary); margin-bottom: 20px; }

  .cards { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; margin-bottom: 24px; }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 14px;
    box-shadow: var(--shadow-sm);
  }
  .card .num { font-size: 28px; font-weight: 700; margin: 4px 0; color: var(--text-primary); }
  .card .lbl { font-size: 10px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-secondary); font-weight: 500; }
  .card.ok .num { color: var(--success); }
  .card.warn .num { color: var(--warning); }
  .card.err .num { color: var(--danger); }
  .card.ml .num { color: var(--warning-amber); }
  .card.muted .num { color: var(--text-muted); }

  section.table-section { margin-bottom: 24px; scroll-margin-top: 16px; }

  table {
    width: 100%;
    background: var(--surface);
    border-collapse: collapse;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
  }
  th {
    background: var(--brand-navy);
    color: #ffffff;
    text-align: left;
    padding: 12px 14px;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 600;
  }
  td {
    padding: 12px 14px;
    border-top: 1px solid var(--border-row);
    font-size: 13px;
    vertical-align: top;
    color: var(--text-primary);
  }
  tbody tr[data-row="main"] { scroll-margin-top: 80px; }
  tr:nth-child(4n+1) td { background: var(--surface); }
  tr:nth-child(4n+3) td { background: var(--surface-alt); }
  tr:hover td { background: var(--surface-hover); }
  tr:target td { background: var(--accent-dim) !important; outline: 2px solid var(--accent); outline-offset: -2px; }

  .tag { display: inline-block; padding: 4px 10px; border-radius: var(--radius-sm); font-size: 11px; font-weight: 600; letter-spacing: 0.3px; }
  .tag.aprovada { background: var(--success-bg); color: var(--success-fg); }
  .tag.divergencia { background: var(--warning-bg); color: var(--warning-fg); }
  .tag.bloqueada { background: var(--danger-bg); color: var(--danger-fg); }
  .tag.aguardando_ml { background: var(--warning-bg); color: var(--warning-amber); }
  .tag.ja_processada { background: rgba(145, 152, 165, 0.18); color: var(--text-secondary); }
  .tag.sem_card_pipefy { background: var(--info-bg); color: var(--info-fg); }

  .motivo { color: var(--danger); font-size: 12px; }
  .right { text-align: right; }
  .mono { font-family: var(--font-mono); }
  .val-diff { color: var(--danger); font-weight: 700; }
  .val-diff-note { font-size: 10px; color: var(--danger); font-weight: 400; }

  .action-banner { padding: 6px 12px; border-radius: var(--radius-md); font-size: 12px; font-weight: 700; margin-bottom: 6px; display: inline-block; letter-spacing: 0.3px; }
  .action-banner.recusar { background: var(--danger); color: #fff; }
  .action-banner.aprovar { background: var(--success); color: #fff; }
  .action-banner.atencao { background: var(--warning); color: #fff; }

  .reinc-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 700;
    min-width: 110px;
    text-align: center;
    border-left: 3px solid;
  }

  .meta {
    margin-top: 24px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    font-size: 11px;
    color: var(--text-secondary);
    box-shadow: var(--shadow-sm);
  }

  a { color: var(--link); text-decoration: none; }
  a:hover { color: var(--link-hover); text-decoration: underline; }

  details summary { cursor: pointer; font-size: 11px; color: var(--text-secondary); list-style: revert; }
  details ul { font-size: 11px; margin: 6px 0 0 0; padding-left: 16px; color: var(--text-secondary); line-height: 1.5; }
  details a { color: var(--link); text-decoration: none; }
  details a:hover { text-decoration: underline; color: var(--link-hover); }

  /* Botão de copiar placa */
  .placa-wrap { display: inline-flex; align-items: center; gap: 4px; }
  .btn-copy {
    cursor: pointer;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 2px 6px;
    font-size: 11px;
    line-height: 1;
    color: var(--text-secondary);
    transition: background 120ms, border-color 120ms, color 120ms;
  }
  .btn-copy:hover { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); }
  .btn-copy:active { background: var(--accent-dim); }
  .btn-copy.copied { background: var(--success-bg); border-color: var(--success); color: var(--success-fg); }

  /* Sub-linha de detalhe */
  tr.subline td {
    background: var(--surface-alt) !important;
    border-top: 0;
    padding-top: 6px;
    padding-bottom: 12px;
    font-size: 11px;
    color: var(--text-secondary);
  }
  tr.subline .lbl {
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-right: 4px;
    font-size: 10px;
  }
  tr.subline .sep { color: var(--border); margin: 0 8px; }

  /* Lista de peças */
  details.pecas summary { color: var(--text-primary); font-weight: 600; font-size: 11px; }
  details.pecas summary:hover { color: var(--accent); }
  details.pecas ul { color: var(--text-secondary); font-size: 12px; }
  details.pecas li.reincidente {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--danger);
    padding: 4px 10px;
    margin: 4px 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    box-shadow: var(--shadow-sm);
  }
  details.pecas li.reincidente::before { content: "🔁 "; }
  details.pecas li.reincidente strong { color: var(--danger-fg); }

  /* Toast feedback */
  #copy-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: var(--surface);
    color: var(--text-primary);
    border: 1px solid var(--border);
    padding: 10px 16px;
    border-radius: var(--radius-md);
    font-size: 13px;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    pointer-events: none;
    transition: opacity 250ms ease;
  }
  #copy-toast.show { opacity: 1; }

  /* Impressão — força light + quebras limpas */
  @media print {
    :root {
      --bg-base: #ffffff;
      --surface: #ffffff;
      --surface-alt: #fafbfd;
      --surface-hover: #ffffff;
      --border: #d4dae8;
      --border-row: #eef1f5;
      --text-primary: #1a2332;
      --text-secondary: #5a6c7f;
      --text-muted: #6b7280;
      --link: #2563eb;
      --link-hover: #1d4ed8;
    }
    body { padding: 12px; font-size: 11px; }
    #theme-toggle, nav.toc, #copy-toast, .btn-copy { display: none !important; }
    .report-header { border-bottom: 2px solid var(--brand-navy); }
    section.table-section, .executive-summary, .meta { page-break-inside: avoid; break-inside: avoid; }
    tr { page-break-inside: avoid; break-inside: avoid; }
    thead { display: table-header-group; }
    tfoot { display: table-footer-group; }
    .tag { border: 1px solid currentColor; background: transparent !important; }
    a { color: var(--brand-navy); text-decoration: underline; }
    .card { box-shadow: none; break-inside: avoid; }
  }
</style>
</head>
{# ----- macros reusáveis ----- #}
{% macro cell_reincidencia(label, divs) %}
  {% set _cores = {
    'sim_com_devolucao_peca':'#2563eb',
    'sim_devolucao_outra_peca':'#ea580c',
    'sim_sem_devolucao':'#dc2626',
    'sim_sem_devolucao_mesmo_forn':'#dc2626',
    'sim_mesmo_forn':'#d97706',
    'sim_outro_forn':'#d97706',
    'sim_devolucao':'#2563eb',
    '—':'#9ca3af'
  } %}
  {% set _textos = {
    'sim_com_devolucao_peca':'Devolução da peça ✅',
    'sim_devolucao_outra_peca':'Devolução de OUTRA peça ⚠️',
    'sim_sem_devolucao':'SEM devolução ❌',
    'sim_sem_devolucao_mesmo_forn':'SEM devolução (mesmo forn.) ❌',
    'sim_mesmo_forn':'Mesmo fornecedor',
    'sim_outro_forn':'Outro fornecedor',
    'sim_devolucao':'Devolução aberta',
    '—':'—'
  } %}
  {% set _cor = _cores.get(label, '#9ca3af') %}
  {% set _txt = _textos.get(label, label) %}
  {% set _is_sem_dev = label in ('sim_sem_devolucao','sim_sem_devolucao_mesmo_forn') %}
  {% set _bg = '#fecaca' if _is_sem_dev else ('#fef3c7' if label not in ('—',) and '—' not in label else 'transparent') %}
  <span class="reinc-badge" style="color:{{ _cor }};border-left-color:{{ _cor }};background:{{ _bg }};">{{ _txt }}{% if divs and divs|length > 1 %} ({{ divs|length }}){% endif %}</span>
  {% if divs %}
    <details style="margin-top:4px;">
      <summary>{{ divs|length }} peça(s) reincidentes</summary>
      <ul style="font-size:11px;margin:4px 0 0 0;padding-left:14px;">
        {% for div in divs %}
          {% set d = div.dados or {} %}
          <li style="margin-bottom:6px;">
            <strong>{{ d.get('descricao_peca','—') }}</strong>
            — {{ d.get('data_anterior','—') }}
            (OC {{ d.get('oc_anterior','—') }}, {{ d.get('fornecedor_anterior_nome','—') }})
            {% if d.get('link_oc_anterior') %} <a href="{{ d.get('link_oc_anterior') }}" target="_blank">[OC anterior]</a>{% endif %}
            <br>
            {% if d.get('tem_devolucao_peca') %}
              <span style="color:#2563eb;">✅ Devolução da peça</span>
              {% if d.get('peca_descricao_devolucao') %} ({{ d.get('peca_descricao_devolucao') }}){% endif %}
              {% if d.get('link_devolucao') %} <a href="{{ d.get('link_devolucao') }}" target="_blank">[Ver card]</a>{% endif %}
            {% elif d.get('tem_devolucao_outra_peca') %}
              <span style="color:#ea580c;">⚠️ Devolução de outra peça</span>
              {% if d.get('peca_descricao_devolucao') %} ({{ d.get('peca_descricao_devolucao') }}){% endif %}
              {% if d.get('link_devolucao') %} <a href="{{ d.get('link_devolucao') }}" target="_blank">[Ver card]</a>{% endif %}
            {% else %}
              <span style="color:#dc2626;font-weight:700;">❌ Nenhum card de devolução — ALERTAR ANALISTA</span>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </details>
  {% endif %}
{% endmacro %}
{% macro cell_cancelamento(label, card_id) %}
  {% set _cor = {'info_incorretas':'#ea580c','cancelado':'#dc2626','ambos':'#dc2626','—':'#9ca3af'}[label] %}
  {% set _txt = {'info_incorretas':'Em revisão','cancelado':'Cancelado','ambos':'Cancelado (rev.)','—':'—'}[label] %}
  <span style="color:{{ _cor }};font-weight:600;">{{ _txt }}</span>
  {% if card_id %}
    <div style="margin-top:4px;">
      <a href="https://app.pipefy.com/pipes/{{ pipe_id }}#cards/{{ card_id }}" target="_blank" rel="noreferrer"
         style="color:#2563eb;font-size:11px;text-decoration:underline;">Ver card</a>
    </div>
  {% endif %}
{% endmacro %}
{# Placa com botão de copiar ao clipboard. O botão não tem acento na descrição
   pra evitar problemas com encoding. O JS inline cuida de feedback. #}
{% macro cell_placa_copiavel(placa) %}
  <span class="placa-wrap mono">
    {{ placa or "—" }}
    {% if placa %}
      <button type="button" class="btn-copy" data-copy="{{ placa }}"
              aria-label="Copiar placa {{ placa }}" title="Copiar placa">📋</button>
    {% endif %}
  </span>
{% endmacro %}
{# Lista expansível de peças. Marca em vermelho as peças cujo `chave_produto`
   está na lista de reincidentes da OC (pré-computada pelo orchestrator). #}
{% macro cell_pecas(produtos, chaves_reincidentes, divs_cross, duplicidades_placa) %}
  {% if produtos %}
    {# Monta mapa de divergências cross-time por chave_produto para lookup rápido #}
    {% set _divs_map = {} %}
    {% if divs_cross %}
      {% for div in divs_cross %}
        {% set d = div.dados or {} %}
        {% if d.get('chave_produto') %}
          {% set _ = _divs_map.update({d.get('chave_produto'): d}) %}
        {% endif %}
      {% endfor %}
    {% endif %}
    {% set _qtd_reinc = chaves_reincidentes|length %}
    {% set _qtd_hist = (duplicidades_placa or [])|length %}
    <details class="pecas">
      <summary>📦 {{ produtos|length }} peça(s){% if _qtd_reinc %} <span style="color:#dc2626;">({{ _qtd_reinc }} duplicada{{ 's' if _qtd_reinc > 1 else '' }} ⚠️)</span>{% endif %}{% if _qtd_hist %} <span style="color:#ea580c;">(+{{ _qtd_hist }} alerta{{ 's' if _qtd_hist > 1 else '' }} placa)</span>{% endif %}</summary>
      <ul>
        {% for p in produtos %}
          {% set _ean = (p.ean or '')|string|trim %}
          {% set _cod = (p.cod_interno or '')|string|trim %}
          {% set _desc = (p.descricao or '')|string|trim|lower %}
          {% if _ean %}{% set _chave = 'ean:' ~ _ean %}
          {% elif _cod %}{% set _chave = 'cod:' ~ _cod %}
          {% else %}{% set _chave = 'desc:' ~ _desc %}
          {% endif %}
          {% set _eh_reinc = _chave in chaves_reincidentes %}
          {% set _div_data = _divs_map.get(_chave, {}) %}
          <li{% if _eh_reinc %} class="reincidente"{% endif %} style="margin-bottom:4px;">
            <strong>{{ p.descricao or "(sem descrição)" }}</strong>
            {% if p.quantidade %} — qtd: {{ p.quantidade }}{% endif %}
            {% if p.valor_unitario %} — R$ {{ "%.2f"|format(p.valor_unitario) }}/un{% endif %}
            {% if p.valor_total %} (total: R$ {{ "%.2f"|format(p.valor_total) }}){% endif %}
            {% if p.qtd_ocs_com_peca is defined and p.qtd_ocs_com_peca and p.qtd_ocs_com_peca > 1 %}
              <span style="color:#dc2626;font-weight:700;background:#fecaca;padding:1px 6px;border-radius:3px;font-size:10px;margin-left:4px;">{{ p.qtd_ocs_com_peca }} OCs</span>
            {% endif %}
            {% if p.ean %} <span style="color:#94a3b8;">[EAN {{ p.ean }}]</span>{% endif %}
            {% if _eh_reinc %}
              <br>
              <span style="color:#dc2626;font-weight:600;">⚠ Duplicada</span>
              — OC anterior: {{ _div_data.get('oc_anterior','—') }} ({{ _div_data.get('data_anterior','—') }})
              {% if _div_data.get('link_oc_anterior') %}<a href="{{ _div_data.get('link_oc_anterior') }}" target="_blank">[ver OC]</a>{% endif %}
              <br>
              {% if _div_data.get('tem_devolucao_peca') %}
                <span style="color:#2563eb;">✅ Devolução aberta</span>
                {% if _div_data.get('peca_descricao_devolucao') %}({{ _div_data.get('peca_descricao_devolucao') }}){% endif %}
                {% if _div_data.get('link_devolucao') %}<a href="{{ _div_data.get('link_devolucao') }}" target="_blank">[ver card]</a>{% endif %}
              {% elif _div_data.get('tem_devolucao_outra_peca') %}
                <span style="color:#ea580c;">⚠️ Devolução de outra peça</span>
                {% if _div_data.get('peca_descricao_devolucao') %}({{ _div_data.get('peca_descricao_devolucao') }}){% endif %}
                {% if _div_data.get('link_devolucao') %}<a href="{{ _div_data.get('link_devolucao') }}" target="_blank">[ver card]</a>{% endif %}
              {% else %}
                <span style="color:#dc2626;font-weight:700;">❌ Sem devolução — ALERTAR</span>
              {% endif %}
            {% endif %}
          </li>
        {% endfor %}
      </ul>
      {# --- Outras duplicidades históricas da placa (peças NÃO na OC atual) --- #}
      {% if duplicidades_placa %}
        <div style="margin-top:8px;padding:8px;background:#fef3c7;border-left:3px solid #f59e0b;border-radius:4px;">
          <strong style="color:#92400e;font-size:12px;">⚠ Outras duplicidades desta placa (7m):</strong>
          <ul style="font-size:11px;margin:4px 0 0 0;padding-left:14px;">
            {% for dup in duplicidades_placa %}
              <li style="margin-bottom:6px;">
                <strong>{{ dup.descricao }}</strong> — {{ dup.total_ocorrencias }}x comprada
                <br>
                {% for oc in dup.ocs %}
                  OC {{ oc.id_pedido }} ({{ oc.data_oc }}, {{ oc.fornecedor }})
                  {% if oc.link_card %}<a href="{{ oc.link_card }}" target="_blank">[card]</a>{% endif %}
                  {% if not loop.last %} · {% endif %}
                {% endfor %}
                <br>
                {% if dup.tem_devolucao %}
                  <span style="color:#2563eb;">✅ Devolução aberta</span>
                  {% if dup.link_devolucao %}<a href="{{ dup.link_devolucao }}" target="_blank">[ver card]</a>{% endif %}
                {% else %}
                  <span style="color:#dc2626;font-weight:700;">❌ Sem devolução — ALERTAR EQUIPE</span>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </details>
  {% elif produtos is none %}
    <span style="background:#fef3c7;border:1px solid #fde68a;border-radius:4px;padding:2px 8px;color:#92400e;font-size:11px;">Dados de pecas nao carregados -- execute nova validacao</span>
  {% else %}
    <span style="color:#9ca3af;font-size:11px;">—</span>
  {% endif %}
{% endmacro %}
{# Modo deeplink: link clicável para verificação manual no Cilia. O Cilia
   não permite scraping (reCAPTCHA Enterprise), então o analista clica
   no link, faz login no Cilia e busca a placa para confirmar peças.
   O link abre direto na página de orçamentos e a placa é copiável com 1 clique. #}
{% macro cell_cilia(placa) %}
  {% if cilia_mode == 'deeplink' %}
    {% set placa_busca = placa or '' %}
    <a href="{{ cilia_base_url }}" target="_blank" rel="noreferrer"
       title="Abrir Cilia — Orçamentos"
       style="color:#2563eb;font-size:12px;text-decoration:underline;font-weight:600;">
      🔗 Abrir Cilia
    </a>
    {% if placa_busca %}
      <div style="margin-top:3px;display:inline-flex;align-items:center;gap:4px;">
        <code onclick="navigator.clipboard.writeText('{{ placa_busca }}');this.style.background='#d1fae5';this.title='Copiada!';setTimeout(()=>{this.style.background='#f1f5f9';this.title='Clique para copiar'},1200)"
              title="Clique para copiar"
              style="cursor:pointer;background:#f1f5f9;border:1px solid #cbd5e1;border-radius:4px;padding:2px 6px;font-size:12px;font-weight:700;letter-spacing:1px;color:#1a2332;user-select:all;transition:background .2s">
          {{ placa_busca }}
        </code>
      </div>
    {% endif %}
  {% elif cilia_mode == 'off' %}
    <span style="color:#9ca3af;">—</span>
  {% else %}
    <span style="color:#9ca3af;font-size:11px;">{{ cilia_mode }}</span>
  {% endif %}
{% endmacro %}
<body>
  <header class="report-header">
    <div>
      <h1>Validação de Ordens de Compra — {{ data_d1 }}</h1>
      <p class="meta-inline">
        Gerado em <strong>{{ gerado_em }}</strong> · Executado por <strong>{{ executado_por }}</strong>
        · <strong>{{ 'DRY-RUN' if dry_run else 'APLICADO' }}</strong>
      </p>
    </div>
    <button id="theme-toggle" type="button" aria-label="Alternar tema claro/escuro" title="Alternar tema">
      <span aria-hidden="true">🌙</span> Tema
    </button>
  </header>

  {% if historico_status and not historico_status.completo %}
  <div style="background: var(--danger-bg); border-left: 4px solid var(--danger); padding: 12px; margin-bottom: 16px; border-radius: var(--radius-sm); color: var(--danger-fg);">
    <strong style="font-size:14px;">⚠ HISTÓRICO DE DUPLICIDADES INCOMPLETO</strong>
    <p style="margin:4px 0 0 0;font-size:12px;">
      Apenas <strong>{{ historico_status.dias_cobertos }}/{{ historico_status.dias_necessarios }}</strong> dias populados.
      Alertas de peças duplicadas podem estar incompletos. O sistema continuará baixando o histórico automaticamente nas próximas execuções.
    </p>
  </div>
  {% endif %}

  {# Resumo executivo textual — leitura rápida antes dos números #}
  <section class="executive-summary" id="resumo" aria-label="Resumo executivo">
    <p style="margin:0;">
      <strong>{{ total }} OC(s)</strong> processada(s) em D-1.
      {% if aprovadas %}<span class="ok">{{ aprovadas }} aprovada{{ 's' if aprovadas != 1 else '' }}</span>{% endif %}
      {% if divergentes %}{% if aprovadas %}, {% endif %}<span class="warn">{{ divergentes }} divergência{{ 's' if divergentes != 1 else '' }}</span>{% endif %}
      {% if bloqueadas %}, <span class="err">{{ bloqueadas }} bloqueada{{ 's' if bloqueadas != 1 else '' }}</span>{% endif %}
      {% if aguardando_ml %}, <span class="ml">{{ aguardando_ml }} aguardando ML</span>{% endif %}
      {% if ja_processadas %}, <span class="muted">{{ ja_processadas }} já processada{{ 's' if ja_processadas != 1 else '' }}</span>{% endif %}.
      {% if ocs_orfas %}<br><span class="err">{{ ocs_orfas|length }} OC(s) órfã(s)</span> encontrada(s) no Club sem card correspondente no Pipefy.{% endif %}
    </p>
  </section>

  {# Navegação rápida por seção relevante #}
  <nav class="toc" aria-label="Sumário do relatório">
    <a href="#resumo">Resumo</a>
    <a href="#todas">Todas as OCs ({{ total }})</a>
    {% if divergentes %}<a href="#secao-divergencia">Divergências ({{ divergentes }})</a>{% endif %}
    {% if bloqueadas %}<a href="#secao-bloqueada">Bloqueadas ({{ bloqueadas }})</a>{% endif %}
    {% if aguardando_ml %}<a href="#secao-aguardando_ml">Aguardando ML ({{ aguardando_ml }})</a>{% endif %}
    {% if ocs_orfas %}<a href="#orfas">Órfãs ({{ ocs_orfas|length }})</a>{% endif %}
  </nav>

  <div class="cards">
    <div class="card"><div class="lbl">Total OCs</div><div class="num">{{ total }}</div></div>
    <div class="card ok"><div class="lbl">Aprovadas</div><div class="num">{{ aprovadas }}</div></div>
    <div class="card warn"><div class="lbl">Divergências</div><div class="num">{{ divergentes }}</div></div>
    <div class="card err"><div class="lbl">Bloqueadas</div><div class="num">{{ bloqueadas }}</div></div>
    <div class="card ml"><div class="lbl">Aguardando ML</div><div class="num">{{ aguardando_ml }}</div></div>
    <div class="card muted"><div class="lbl">Já processadas</div><div class="num">{{ ja_processadas }}</div></div>
  </div>

  {% if modo_operacao == 'consulta' %}
  <div style="background: var(--warning-bg); border: 1px solid var(--warning); border-radius: var(--radius-lg); padding: 12px 16px; margin-bottom: 16px; color: var(--warning-fg); font-size: 13px;">
    ⚠️ <strong>MODO CONSULTA</strong> — Nenhuma ação foi aplicada no Pipefy nem e-mails enviados. As ações sugeridas estão na coluna "Ação sugerida".
  </div>
  {% endif %}

  {# Modo deeplink: Valor Cilia é sempre vazio, omitimos a coluna.
     Modo stub/http: mostramos a coluna porque tem dados úteis. #}
  {% set _show_valor_cilia = cilia_mode in ('stub','http') %}
  {# Largura das colunas (colspan da sub-linha) — calculado dinamicamente
     com base no que está visível. Hoje a base é 17, +1 se valor_cilia,
     +1 se cilia_mode!=off. #}
  {% set _ncols = 17 + (1 if _show_valor_cilia else 0) + (1 if cilia_mode != 'off' else 0) %}
  {# Para deep-linking por status: guardamos o primeiro idx de cada status visto
     na iteração e injetamos id="secao-<status>" apenas na primeira ocorrência. #}
  {% set _primeiros_status = namespace(vistos=[]) %}
  <section class="table-section" id="todas" aria-label="Todas as OCs">
  <table>
    <thead>
      <tr>
        <th>Nº OC</th>
        <th>Placa</th>
        <th>Fornecedor</th>
        <th class="right">Valor Card</th>
        <th class="right">Valor Club</th>
        <th class="right">Valor PDF</th>
        {% if _show_valor_cilia %}<th class="right">Valor Cilia</th>{% endif %}
        <th class="right">Qtd Cotações</th>
        <th>Peça Duplicada</th>
        <th>Reincidência (7m)</th>
        <th>Cancelamento</th>
        {% if cilia_mode != 'off' %}<th>Cília</th>{% endif %}
        <th>Status</th>
        <th>Ação Sugerida</th>
        <th>Card</th>
        <th>Motivo</th>
        <th>Fase Atual</th>
        <th>Fase Destino</th>
      </tr>
    </thead>
    <tbody>
    {% for r in resultados %}
      {% set _st = r.status.value %}
      {% set _row_id = 'oc-' ~ r.oc.id_pedido %}
      {% if _st not in _primeiros_status.vistos %}
        {% set _ = _primeiros_status.vistos.append(_st) %}
        {% set _row_id = 'secao-' ~ _st %}
      {% endif %}
      <tr id="{{ _row_id }}" data-row="main" data-status="{{ _st }}">
        <td class="mono">{{ r.oc.id_pedido }}</td>
        <td>{{ cell_placa_copiavel(r.oc.identificador) }}</td>
        <td>{{ (r.oc.fornecedor.for_nome if r.oc.fornecedor else "") or "—" }}</td>
        <td class="right mono"><strong>{{ "R$ %.2f"|format(r.valor_card) if r.valor_card else "—" }}</strong></td>
        <td class="right mono">{{ "R$ %.2f"|format(r.valor_club) if r.valor_club else "—" }}</td>
        {% if r.valor_club and r.valor_pdf and r.valor_club != r.valor_pdf %}
        <td class="right mono val-diff">{{ "R$ %.2f"|format(r.valor_pdf) }}<br><span class="val-diff-note">≠ Club: {{ "R$ %.2f"|format(r.valor_club) }}</span></td>
        {% else %}
        <td class="right mono">{{ "R$ %.2f"|format(r.valor_pdf) if r.valor_pdf else "—" }}</td>
        {% endif %}
        {% if _show_valor_cilia %}<td class="right mono">{{ "R$ %.2f"|format(r.valor_cilia) if r.valor_cilia else "—" }}</td>{% endif %}
        <td class="right">{{ r.qtd_cotacoes or 0 }}</td>
        <td>{{ r.peca_duplicada }}</td>
        <td>{{ cell_reincidencia(r.reincidencia, r.divergencias_cross) }}</td>
        <td>{{ cell_cancelamento(r.cancelamento, r.cancelamento_card_id) }}</td>
        {% if cilia_mode != 'off' %}<td>{{ cell_cilia(r.oc.identificador) }}</td>{% endif %}
        <td><span class="tag {{ r.status.value }}">{{ {'aprovada':'Aprovada','divergencia':'Divergência','bloqueada':'Bloqueada','aguardando_ml':'ML — Manual','ja_processada':'Já processada','sem_card_pipefy':'Sem card Pipefy'}[r.status.value] }}</span></td>
        <td>{{ acao_sugerida(r) }}</td>
        <td>
          {% set lk = link_card(r.card_pipefy_id) %}
          {% if lk %}<a href="{{ lk }}" target="_blank" rel="noopener">abrir</a>{% else %}—{% endif %}
        </td>
        <td class="motivo">
          {%- if r.status.value == 'aguardando_ml' -%}
            Fornecedor Mercado Livre — requer validação manual
          {%- elif r.status.value == 'ja_processada' -%}
            Card já estava em fase "{{ r.fase_pipefy_atual or '?' }}"
          {%- elif r.status.value == 'sem_card_pipefy' -%}
            OC sem card no Pipefy — requer criação manual
          {%- else -%}
            {{ r.motivo_resumido or "—" }}
          {%- endif -%}
        </td>
        <td>{{ r.fase_pipefy_atual or "—" }}</td>
        <td>{{ r.fase_destino.value if r.fase_destino else "—" }}</td>
      </tr>
      {# Sub-linha cinza com Forma de Pagamento + Cotação + Comprador + botão Peças #}
      <tr class="subline">
        <td colspan="{{ _ncols }}">
          {# Action guidance banner #}
          {% set _has_reinc = r.divergencias_cross and r.divergencias_cross|length > 0 %}
          {% set _reinc_sem_dev = r.reincidencia in ('sim_sem_devolucao','sim_sem_devolucao_mesmo_forn') %}
          {% set _reinc_com_dev = r.reincidencia == 'sim_com_devolucao_peca' %}
          {% set _low_quotes = (r.qtd_cotacoes or 0) < 3 %}
          {% if _has_reinc and _reinc_sem_dev %}
            <span class="action-banner recusar">RECUSAR -- Sem card de devolucao no Pipefy</span><br>
          {% elif _has_reinc and _reinc_com_dev %}
            <span class="action-banner aprovar">APROVAR -- Devolucao confirmada</span><br>
          {% elif _low_quotes %}
            <span class="action-banner atencao">ATENCAO -- Menos de 3 cotacoes</span><br>
          {% endif %}
          <span class="lbl">Forma:</span>{{ r.forma_pagamento_canonica or "—" }}
          <span class="sep">·</span>
          <span class="lbl">Cotação:</span><span class="mono">{{ r.oc.id_cotacao or "—" }}</span>
          <span class="sep">·</span>
          <span class="lbl">Comprador:</span>{{ r.oc.comprador_nome or ("#" ~ r.oc.created_by if r.oc.created_by else "—") }}
          <span class="sep">·</span>
          {{ cell_pecas(r.produtos, r.chaves_reincidentes, r.divergencias_cross, r.duplicidades_placa) }}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  </section>

  {% if ocs_orfas %}
  <section class="table-section" id="orfas" aria-label="OCs órfãs">
  <h2>Revisão final — OCs órfãs ({{ ocs_orfas|length }})</h2>
  <p style="color: var(--text-secondary); font-size: 13px; margin-top: 0;">OCs encontradas no Club sem card correspondente no Pipefy — requer revisão manual.</p>
  <table>
    <thead>
      <tr>
        <th>Nº Pedido</th>
        <th>Cotação</th>
        <th>Placa</th>
        <th>Fornecedor</th>
        <th>Comprador</th>
        <th>Forma</th>
        <th class="right">Valor Club</th>
        <th>Qtd Itens</th>
        <th>Peça Duplicada</th>
        <th>Reincidência (7m)</th>
        <th>Cancelamento</th>
        {% if cilia_mode != 'off' %}<th>Cília</th>{% endif %}
      </tr>
    </thead>
    <tbody>
    {% set _ncols_orfas = 11 + (1 if cilia_mode != 'off' else 0) %}
    {% for o in ocs_orfas %}
      <tr>
        <td class="mono">{{ o.id_pedido }}</td>
        <td class="mono">{{ o.id_cotacao or "—" }}</td>
        <td>{{ cell_placa_copiavel(o.identificador) }}</td>
        <td>{{ o.fornecedor or "—" }}</td>
        <td>{{ o.comprador or "—" }}</td>
        <td>{{ o.forma_pagamento or "—" }}</td>
        <td class="right mono">{{ "R$ %.2f"|format(o.valor) if o.valor else "—" }}</td>
        <td class="right">{{ o.qtd_produtos if o.qtd_produtos is not none else "—" }}</td>
        <td>{{ o.peca_duplicada }}</td>
        <td>{{ cell_reincidencia(o.reincidencia, o.divergencias) }}</td>
        <td>{{ cell_cancelamento(o.cancelamento, o.cancelamento_card_id) }}</td>
        {% if cilia_mode != 'off' %}<td>{{ cell_cilia(o.identificador) }}</td>{% endif %}
      </tr>
      <tr class="subline">
        <td colspan="{{ _ncols_orfas }}">
          {{ cell_pecas(o.produtos, o.chaves_reincidentes, o.divergencias, o.duplicidades_placa) }}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  </section>
  {% endif %}

  <div class="meta">
    Pipe Pipefy: <span class="mono">{{ pipe_id }}</span> ·
    Validador: <span class="mono">{{ executado_por }}</span> ·
    Rastreabilidade: cada chamada de API foi registrada em <span class="mono">auditoria_api</span>.
  </div>

  <!-- Toast acessível para feedback de "copiado" -->
  <div id="copy-toast" role="status" aria-live="polite"></div>

  <!-- Toggle dark/light com persistência em localStorage. Dark é o default. -->
  <script>
    (function () {
      var KEY = "validador-oc-report-theme";
      var saved = null;
      try { saved = localStorage.getItem(KEY); } catch (_) {}
      if (saved === "light" || saved === "dark") {
        document.documentElement.setAttribute("data-theme", saved);
      }
      var btn = document.getElementById("theme-toggle");
      if (!btn) return;
      function render() {
        var cur = document.documentElement.getAttribute("data-theme") || "dark";
        btn.innerHTML = (cur === "dark" ? '<span aria-hidden="true">🌙</span> Tema escuro' : '<span aria-hidden="true">☀️</span> Tema claro');
      }
      render();
      btn.addEventListener("click", function () {
        var cur = document.documentElement.getAttribute("data-theme") || "dark";
        var next = cur === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        try { localStorage.setItem(KEY, next); } catch (_) {}
        render();
      });
    })();
  </script>

  <!--
    JavaScript inline (puro client-side, sem chamadas externas):
      - Listener delegado para botões .btn-copy → copia data-copy ao clipboard
      - Fallback document.execCommand para browsers antigos
      - Feedback visual (botão pisca verde) + aria-live (toast)
    Limite: se este script crescer >50 linhas, refatorar para frontend React.
  -->
  <script>
    (function () {
      const toast = document.getElementById('copy-toast');
      function showToast(msg) {
        if (!toast) return;
        toast.textContent = msg;
        toast.classList.add('show');
        setTimeout(function () { toast.classList.remove('show'); }, 1800);
      }
      function copyFallback(text) {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (_) {}
        document.body.removeChild(ta);
      }
      async function copyText(text) {
        if (navigator.clipboard && window.isSecureContext) {
          try { await navigator.clipboard.writeText(text); return true; }
          catch (_) { copyFallback(text); return true; }
        }
        copyFallback(text);
        return true;
      }
      document.addEventListener('click', function (ev) {
        const btn = ev.target.closest('.btn-copy');
        if (!btn) return;
        ev.preventDefault();
        const text = btn.getAttribute('data-copy') || '';
        if (!text) return;
        copyText(text).then(function () {
          btn.classList.add('copied');
          const orig = btn.textContent;
          btn.textContent = '✓';
          showToast('Copiado: ' + text);
          setTimeout(function () {
            btn.classList.remove('copied');
            btn.textContent = orig;
          }, 1500);
        });
      });
    })();
  </script>
</body>
</html>
